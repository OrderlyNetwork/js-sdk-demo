{
  "name": "orderly-js-sdk-vite-template",
  "description": "Template for Orderly SDK v2 based on Vite",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm start:staging",
    "start:dev": "vite --mode dev --port 4564",
    "start:qa": "vite --mode qa --port 4565",
    "start:staging": "vite --mode staging --port 4567",
    "start:prod": "vite --mode prod --port 4568",
    "start:prod-iap": "vite --mode prod-iap --port 4569",
    "build": "tsc --noEmit && vite build",
    "start": "vite preview",
    "preview": "vite preview",
    "lint": "eslint . && tsc --noEmit",
    "test": "vitest run && sh tests/entrypoint.test.sh",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "prepare": "husky",
    "release": "node scripts/release.js",
    "release:dev": "VITE_APP_TARGET=demo orderly-release-tag --env dev --project-id 34815052",
    "release:dev:demo": "VITE_APP_TARGET=demo orderly-release-tag --env dev --project-id 34815052",
    "release:dev:dmm": "VITE_APP_TARGET=dmm orderly-release-tag --env dev --project-id 34815052",
    "release:qa": "VITE_APP_TARGET=demo orderly-release-tag --env qa --project-id 34815052",
    "release:qa:demo": "VITE_APP_TARGET=demo orderly-release-tag --env qa --project-id 34815052",
    "release:qa:dmm": "VITE_APP_TARGET=dmm orderly-release-tag --env qa --project-id 34815052",
    "release:prod": "VITE_APP_TARGET=demo orderly-release-tag --env prod --project-id 34815052",
    "release:prod:demo": "VITE_APP_TARGET=demo orderly-release-tag --env prod --project-id 34815052",
    "release:prod:dmm": "VITE_APP_TARGET=dmm orderly-release-tag --env prod --project-id 34815052",
    "updateSdkVersion": "node scripts/updateSdkVersion.js"
  },
  "dependencies": {
    "@orderly.network/affiliate": "3.1.6-internal-20260717.3",
    "@orderly.network/core": "3.1.6-internal-20260717.3",
    "@orderly.network/fast-place-order-plugin": "^0.2.4",
    "@orderly.network/hooks": "3.1.6-internal-20260717.3",
    "@orderly.network/i18n": "3.1.6-internal-20260717.3",
    "@orderly.network/markets": "3.1.6-internal-20260717.3",
    "@orderly.network/onramper-plugin": "^0.3.1",
    "@orderly.network/orderbook-shimmer-plugin": "^0.0.4",
    "@orderly.network/portfolio": "3.1.6-internal-20260717.3",
    "@orderly.network/react-app": "3.1.6-internal-20260717.3",
    "@orderly.network/trading": "3.1.6-internal-20260717.3",
    "@orderly.network/trading-leaderboard": "3.1.6-internal-20260717.3",
    "@orderly.network/trading-rewards": "3.1.6-internal-20260717.3",
    "@orderly.network/types": "3.1.6-internal-20260717.3",
    "@orderly.network/ui": "3.1.6-internal-20260717.3",
    "@orderly.network/ui-notification": "3.1.6-internal-20260717.3",
    "@orderly.network/ui-scaffold": "3.1.6-internal-20260717.3",
    "@orderly.network/vaults": "3.1.6-internal-20260717.3",
    "@orderly.network/wallet-connector-privy": "3.1.6-internal-20260717.3",
    "@solana-mobile/wallet-adapter-mobile": "^2.1.4",
    "@solana/wallet-adapter-base": "^0.9.23",
    "@solana/wallet-adapter-wallets": "^0.19.38",
    "@solana/web3.js": "^1.95.3",
    "@sentry/react": "^10.67.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@orderly.network/release-tag": "^1.0.2",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^20.19.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@sentry/vite-plugin": "^5.4.0",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fs-extra": "^11.2.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.6",
    "typescript": "^5",
    "typescript-eslint": "^8.60.1",
    "vite": "^7.0.4",
    "vite-plugin-node-polyfills": "^0.24.0",
    "vitest": "^4.1.10",
    "zx": "^8.8.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "@solana/wallet-adapter-walletconnect>@walletconnect/solana-adapter": "0.0.9",
      "@trezor/protobuf>protobufjs": "7.6.3",
      "@ethersproject/providers>ws": "8.21.0",
      "socket.io-client>engine.io-client": "6.6.6",
      "viem>ws": "8.21.0"
    }
  }
}
