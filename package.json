{
  "name": "orderly-js-sdk-vite-template",
  "description": "Template for Orderly SDK v2 based on Vite",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "start": "vite preview",
    "preview": "vite preview",
    "lint": "eslint . && tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "copyLocales": "node scripts/copyLocales.js",
    "prepare": "husky",
    "release": "node scripts/release.js",
    "release:dev": "VITE_APP_TARGET=demo orderly-release-tag --env dev --project-id 34815052",
    "release:dev:demo": "VITE_APP_TARGET=demo orderly-release-tag --env dev --project-id 34815052",
    "release:dev:dmm": "VITE_APP_TARGET=dmm orderly-release-tag --env dev --project-id 34815052",
    "release:qa": "VITE_APP_TARGET=demo orderly-release-tag --env qa --project-id 34815052",
    "release:qa:demo": "VITE_APP_TARGET=demo orderly-release-tag --env qa --project-id 34815052",
    "release:qa:dmm": "VITE_APP_TARGET=dmm orderly-release-tag --env qa --project-id 34815052",
    "release:prod": "VITE_APP_TARGET=demo orderly-release-tag --env prod --project-id 34815052",
    "release:prod:demo": "VITE_APP_TARGET=demo orderly-release-tag --env prod --project-id 34815052",
    "release:prod:dmm": "VITE_APP_TARGET=dmm orderly-release-tag --env prod --project-id 34815052",
    "updateSdkVersion": "node scripts/updateSdkVersion.js"
  },
  "dependencies": {
    "@orderly.network/affiliate": "3.1.1-internal-pretge-listing.3",
    "@orderly.network/fast-place-order-plugin": "^0.2.4",
    "@orderly.network/hooks": "3.1.1-internal-pretge-listing.3",
    "@orderly.network/i18n": "3.1.1-internal-pretge-listing.3",
    "@orderly.network/markets": "3.1.1-internal-pretge-listing.3",
    "@orderly.network/onramper-plugin": "^0.3.1",
    "@orderly.network/orderbook-shimmer-plugin": "^0.0.4",
    "@orderly.network/portfolio": "3.1.1-internal-pretge-listing.3",
    "@orderly.network/react-app": "3.1.1-internal-pretge-listing.3",
    "@orderly.network/trading": "3.1.1-internal-pretge-listing.3",
    "@orderly.network/trading-leaderboard": "3.1.1-internal-pretge-listing.3",
    "@orderly.network/trading-rewards": "3.1.1-internal-pretge-listing.3",
    "@orderly.network/types": "3.1.1-internal-pretge-listing.3",
    "@orderly.network/ui": "3.1.1-internal-pretge-listing.3",
    "@orderly.network/ui-scaffold": "3.1.1-internal-pretge-listing.3",
    "@orderly.network/wallet-connector-privy": "3.1.1-internal-pretge-listing.3",
    "@solana-mobile/wallet-adapter-mobile": "2.1.4",
    "@solana/wallet-adapter-base": "0.9.23",
    "@solana/wallet-adapter-wallets": "0.19.32",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@orderly.network/release-tag": "^1.0.0",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^20.19.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fs-extra": "^11.2.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "^3.6.2",
    "typescript": "^5",
    "typescript-eslint": "^8.60.1",
    "vite": "^7.0.4",
    "vite-plugin-node-polyfills": "^0.24.0",
    "zx": "^8.8.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "@solana/wallet-adapter-walletconnect>@walletconnect/solana-adapter": "0.0.9",
      "@trezor/protobuf>protobufjs": "7.6.3",
      "@ethersproject/providers>ws": "8.21.0",
      "socket.io-client>engine.io-client": "6.6.6",
      "viem>ws": "8.21.0"
    }
  }
}
