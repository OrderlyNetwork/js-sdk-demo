{
  "name": "orderly-js-sdk-nextjs-template",
  "description": "Template for Orderly SDK v2 based on Next.js",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "copyLocales": "node scripts/copyLocales.js",
    "prepare": "husky",
    "release": "node scripts/release.js",
    "release:dev": "orderly-release-tag --env dev --project-id 34815052",
    "release:qa": "orderly-release-tag --env qa --project-id 34815052",
    "release:prod": "orderly-release-tag --env prod --project-id 34815052",
    "updateSdkVersion": "node scripts/updateSdkVersion.js"
  },
  "dependencies": {
    "@orderly.network/affiliate": "3.0.4-internal-20260521.4",
    "@orderly.network/fast-place-order-plugin": "^0.2.4",
    "@orderly.network/hooks": "3.0.4-internal-20260521.4",
    "@orderly.network/i18n": "3.0.4-internal-20260521.4",
    "@orderly.network/markets": "3.0.4-internal-20260521.4",
    "@orderly.network/onramper-plugin": "^0.3.1",
    "@orderly.network/orderbook-shimmer-plugin": "^0.0.4",
    "@orderly.network/portfolio": "3.0.4-internal-20260521.4",
    "@orderly.network/react-app": "3.0.4-internal-20260521.4",
    "@orderly.network/trading": "3.0.4-internal-20260521.4",
    "@orderly.network/trading-leaderboard": "3.0.4-internal-20260521.4",
    "@orderly.network/trading-rewards": "3.0.4-internal-20260521.4",
    "@orderly.network/types": "3.0.4-internal-20260521.4",
    "@orderly.network/ui": "3.0.4-internal-20260521.4",
    "@orderly.network/ui-scaffold": "3.0.4-internal-20260521.4",
    "@orderly.network/wallet-connector-privy": "3.0.4-internal-20260521.4",
    "@solana-mobile/wallet-adapter-mobile": "2.1.4",
    "@solana/wallet-adapter-base": "0.9.23",
    "@solana/wallet-adapter-wallets": "0.19.32",
    "next": "15.4.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@orderly.network/release-tag": "^1.0.0",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "15.0.2",
    "fs-extra": "^11.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "^3.6.2",
    "typescript": "^5",
    "zx": "^8.8.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ]
  }
}
